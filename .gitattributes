* text=auto eol=lf

# Windows-native scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files — never normalize
*.png binary
*.svg binary
*.jar binary

# Test fixture with deliberate CRLF bytes — must never be EOL-normalized
scripts/checks/tests/fixtures/crlf.md -text
